---
import Base from '../layouts/Base.astro';
interface Props { title: string; seal: string; desc: string; navKey: string; }
const { title, seal, desc, navKey } = Astro.props;
---
<Base title={`${title} · Jevon's Den`} active={navKey}>
<section class="relative overflow-hidden min-h-[55vh]">
  <div class="blob w-[400px] h-[320px] -top-16 left-[15%]" style="background:rgba(200,162,115,.08)" aria-hidden="true"></div>

  <div class="max-w-[680px] mx-auto px-7 pt-10 pb-24 relative text-center">
    <div class="serif w-14 h-14 mx-auto rounded-2xl border border-[#8a6f4e] text-[#c8a273] flex items-center justify-center text-[24px] mb-8">{seal}</div>
    <h1 class="serif text-[28px] font-medium text-[#eceae5] tracking-[.08em]">{title}</h1>
    <p class="mt-4 text-[14px] text-[#807e88] leading-relaxed max-w-[26em] mx-auto">{desc}</p>
    <div class="serif mt-10 text-[13px] text-[#55535e]">这个房间还在装修，先去别处坐坐。</div>
    <a href="/" class="inline-block mt-8 glass !rounded-2xl px-7 py-3 text-[14px] text-[#c9c7c1] no-underline">回到书房</a>
  </div>
</section>
</Base>
