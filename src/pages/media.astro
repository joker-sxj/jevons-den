---
import Base from '../layouts/Base.astro';

// 网易云真实收藏精选（2026-07 从「我的收藏」整理）
// cover 渐变是占位氛围色，取自专辑封面主色调——不盗链封面图，版权干净
const albums = [
  { title: 'The Dark Side of the Moon', artist: 'Pink Floyd', c: 'linear-gradient(135deg,#0d0d0d,#3d2a4d 60%,#7a4a2a)', note: '一切的起点，也是终点' },
  { title: 'Wish You Were Here', artist: 'Pink Floyd', c: 'linear-gradient(150deg,#c9b8a0,#8a7a66)', note: '两个机器人握手，人却缺席' },
  { title: 'The Wall', artist: 'Pink Floyd', c: 'linear-gradient(135deg,#e8e4dc,#b8b4ac)', note: '' },
  { title: 'The Piper at the Gates of Dawn', artist: 'Pink Floyd', c: 'linear-gradient(140deg,#8a2a2a,#4a2a3d)', note: 'Syd 的迷幻童话' },
  { title: 'In the Court of the Crimson King', artist: 'King Crimson', c: 'linear-gradient(135deg,#c94a3a,#7a2a4a)', note: '那张尖叫的脸' },
  { title: 'Red', artist: 'King Crimson', c: 'linear-gradient(140deg,#1a1a1a,#5a1a1a)', note: '' },
  { title: 'Close to the Edge', artist: 'Yes', c: 'linear-gradient(180deg,#8ab86a,#1a3d1a)', note: '前卫摇滚的天花板' },
  { title: 'Abbey Road', artist: 'The Beatles', c: 'linear-gradient(140deg,#6a8ab8,#3d4a5a)', note: '' },
  { title: 'Sgt. Pepper’s Lonely Hearts Club Band', artist: 'The Beatles', c: 'linear-gradient(135deg,#c9a83a,#8a3a3a)', note: '' },
  { title: 'Electric Ladyland', artist: 'Jimi Hendrix', c: 'linear-gradient(135deg,#c93a2a,#7a1a1a)', note: '' },
  { title: 'Led Zeppelin II', artist: 'Led Zeppelin', c: 'linear-gradient(140deg,#b8a87a,#5a4a2a)', note: '' },
  { title: 'Use Your Illusion I & II', artist: 'Guns N’ Roses', c: 'linear-gradient(135deg,#3a5ac9,#c9a83a)', note: '' },
  { title: '万能青年旅店（同名）', artist: '万能青年旅店', c: 'linear-gradient(140deg,#b8a878,#6a5a3a)', note: '杀死那个石家庄人' },
  { title: '冀西南林路行', artist: '万能青年旅店', c: 'linear-gradient(135deg,#8a7a5a,#3d3527)', note: '泥河冲出山口，大地忽然辽阔' },
  { title: '黑梦', artist: '窦唯', c: 'linear-gradient(160deg,#9a9a9a,#2a2a2a)', note: '中文摇滚最好的专辑，没有之一' },
  { title: '卡拉OK·台北·我', artist: '张雨生', c: 'linear-gradient(135deg,#3a3a3a,#8a2a2a)', note: '被低估的天才' },
  { title: '丑奴儿', artist: '草东没有派对', c: 'linear-gradient(150deg,#4a4a4a,#1a1a1a)', note: '' },
  { title: '菊花夜行军', artist: '交工乐队', c: 'linear-gradient(135deg,#5aa83a,#2a3d8a)', note: '土地里长出来的音乐' },
  { title: '华北浪革', artist: '刘森', c: 'linear-gradient(140deg,#2a3a8a,#1a1a3d)', note: '' },
  { title: 'American Football (LP1)', artist: 'American Football', c: 'linear-gradient(160deg,#3d4a3d,#1a221a)', note: '那栋房子，那扇窗' },
  { title: 'Interstellar OST', artist: 'Hans Zimmer', c: 'linear-gradient(140deg,#c9c9c9,#5a6a7a)', note: '管风琴一响，人类启程' },
  { title: 'U87', artist: '陈奕迅', c: 'linear-gradient(135deg,#5a7a4a,#2a3d2a)', note: '' },
];
---
<Base title="收藏 · Jevon's Den" active="media">
<section class="relative overflow-hidden">
  <div class="blob w-[460px] h-[360px] -top-20 right-[8%]" style="background:rgba(200,162,115,.09)" aria-hidden="true"></div>

  <div class="max-w-[1000px] mx-auto px-7 pt-10 pb-24 relative">
    <h1 class="serif text-[32px] font-medium text-[#eceae5] tracking-[.06em]">收藏</h1>
    <p class="mt-3 text-[14px] text-[#807e88] max-w-[34em] leading-relaxed">
      我的耳朵长在上个世纪——迷幻与前卫摇滚是主食，Pink Floyd 是本命；
      也爱这片土地上长出来的声音，从窦唯到万青。
    </p>

    <!-- 音乐 -->
    <div class="mt-12">
      <div class="flex items-baseline gap-4 mb-7">
        <span class="serif text-[19px] tracking-[.1em] text-[#eceae5]">唱片</span>
        <span class="mono text-[11px] tracking-[.2em] uppercase text-[#55535e]">On Rotation</span>
        <span class="flex-1 h-px" style="background:linear-gradient(90deg,#2a2a32,transparent)"></span>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {albums.map(a => (
          <div class="group relative">
            <div class="aspect-square rounded-xl shadow-[0_8px_24px_rgba(0,0,0,.4)] flex items-end p-3 transition-transform group-hover:-translate-y-1.5"
                 style={`background:${a.c}`}>
              <div class="w-full">
                <div class="text-[12.5px] font-medium text-white/90 leading-snug" style="text-shadow:0 1px 8px rgba(0,0,0,.6)">{a.title}</div>
                <div class="text-[11px] text-white/60 mt-0.5" style="text-shadow:0 1px 6px rgba(0,0,0,.6)">{a.artist}</div>
              </div>
            </div>
            {a.note && (
              <div class="serif mt-2 text-[11.5px] text-[#807e88] leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity">
                「{a.note}」
              </div>
            )}
          </div>
        ))}
      </div>
      <p class="serif mt-8 text-[12.5px] text-[#55535e]">色块取自每张专辑封面的气质——封面本身，请去唱片店亲眼看。</p>
    </div>

    <!-- 电影与书：施工中 -->
    <div class="mt-16 glass p-7">
      <div class="serif text-[16px] text-[#eceae5] mb-2">电影与书</div>
      <p class="text-[13.5px] text-[#807e88] leading-relaxed">
        豆瓣上的观影和读书记录正在搬运中——很快这里会有海报墙和短评。
      </p>
    </div>
  </div>
</section>
</Base>
