---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(p => ({ params: { slug: p.id }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data.date;
const fmt = `${d.getFullYear()} 年 ${d.getMonth() + 1} 月 ${d.getDate()} 日`;
---
<Base title={`${post.data.title} · Jevon's Den`} active="posts">
<article class="relative overflow-hidden">
  <div class="blob w-[400px] h-[300px] -top-16 right-[-120px]" style="background:rgba(200,162,115,.07)" aria-hidden="true"></div>

  <div class="max-w-[680px] mx-auto px-7 pt-10 pb-24 relative">
    <a href="/posts" class="mono text-[12px] text-[#55535e] hover:text-[#c8a273] no-underline transition-colors">← 回到随笔</a>

    <header class="mt-8 mb-12">
      <h1 class="serif text-[clamp(26px,4vw,34px)] font-medium text-[#eceae5] leading-[1.5]">{post.data.title}</h1>
      <div class="mt-4 flex items-center gap-4 text-[12.5px] text-[#55535e]">
        <span class="mono">{fmt}</span>
        {post.data.tags.map(t => <span class="mono">#{t}</span>)}
      </div>
    </header>

    <div class="prose-den">
      <Content />
    </div>

    <footer class="mt-16 pt-8 border-t border-[#232329] flex justify-between items-center">
      <a href="/posts" class="text-[13.5px] text-[#807e88] hover:text-[#c8a273] no-underline transition-colors">← 更多随笔</a>
      <span class="serif text-[13px] text-[#55535e]">写于深夜书房</span>
    </footer>
  </div>
</article>
</Base>
