---
import Base from '../layouts/Base.astro';

const links = [
  { name: '示例友邻', url: 'https://example.com', desc: '这里等待第一位灯火相邻的朋友' },
];
---
<Base title="友邻 · Jevon's Den" active="links">
<section class="relative overflow-hidden min-h-[55vh]">
  <div class="blob w-[420px] h-[320px] -top-16 right-[-100px]" style="background:rgba(107,86,55,.12)" aria-hidden="true"></div>

  <div class="max-w-[760px] mx-auto px-7 pt-10 pb-24 relative">
    <h1 class="serif text-[32px] font-medium text-[#eceae5] tracking-[.06em]">友邻</h1>
    <p class="mt-3 text-[14px] text-[#807e88]">灯火相邻的那些站。</p>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-5">
      {links.map(l => (
        <a href={l.url} target="_blank" rel="noopener" class="glass p-6 no-underline text-[#c9c7c1]">
          <div class="text-[15px] text-[#eceae5] mb-1.5">{l.name}</div>
          <div class="text-[13px] text-[#807e88] leading-relaxed">{l.desc}</div>
        </a>
      ))}
    </div>

    <div class="mt-14 glass p-7">
      <div class="serif text-[15px] text-[#eceae5] mb-2">交换友链</div>
      <p class="text-[13.5px] text-[#807e88] leading-relaxed">
        欢迎交换。要求只有一个：你的站也得是个有人味儿的地方。
        通过 <a href="https://github.com/joker-sxj" target="_blank" rel="noopener" class="text-[#c8a273]">GitHub</a> 找到我。
      </p>
    </div>
  </div>
</section>
</Base>
